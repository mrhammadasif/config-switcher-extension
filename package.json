{
  "name": "config-switcher",
  "displayName": "Config Switcher",
  "description": "Switch a configurable JSON file between dev and local source files from the status bar.",
  "version": "0.2.0",
  "publisher": "eg",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "url": "https://github.com/mrhammadasif/config-switcher-extension"
  },
  "categories": [
    "Other"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "This extension writes to public/config.json and should only run in trusted workspaces."
    }
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:egConfigSwitcher.toggle"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "egConfigSwitcher.toggle",
        "title": "EG Config Switcher: Toggle Config"
      }
    ],
    "configuration": {
      "title": "Config Switcher",
      "properties": {
        "configSwitcher.devConfigPath": {
          "type": "string",
          "default": "public/config.dev.json",
          "scope": "resource",
          "description": "Workspace-relative path to the dev config source file."
        },
        "configSwitcher.localConfigPath": {
          "type": "string",
          "default": "public/config.local.json",
          "scope": "resource",
          "description": "Workspace-relative path to the local config source file."
        },
        "configSwitcher.targetConfigPath": {
          "type": "string",
          "default": "public/config.json",
          "scope": "resource",
          "description": "Workspace-relative path to the destination config file that will be overwritten."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node --test out/test/configSwitcher.test.js",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.9.3"
  }
}
